---
import '../styles/global.css';
import { SEO } from 'astro-seo';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description = 'Voice AI receptionist for UK small teams. Brackstone answers, qualifies and organises enquiries so follow-ups stay visible without extra admin.', canonical } = Astro.props;
const siteUrl = 'https://brackstonedigital.co.uk';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={title}
      description={description}
      canonical={canonicalUrl}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: `${siteUrl}/og-image.png`,
        },
        optional: {
          description: description,
          siteName: 'Brackstone Digital',
          locale: 'en_GB',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: title,
        description: description,
        image: `${siteUrl}/og-image.png`,
      }}
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800&family=Geist+Mono:wght@400;500&display=swap" />
  </head>
  <body>
    <slot />
  </body>
</html>
