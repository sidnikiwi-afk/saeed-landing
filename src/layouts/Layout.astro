---
import '../styles/global.css';
import { SEO } from 'astro-seo';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description = 'Full-stack digital growth for UK small businesses. Cold email outreach, AI voice agents, high-converting websites, and paid ads — one partner, one system.', canonical } = Astro.props;
const siteUrl = 'https://brackstonedigital.co.uk';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={title}
      description={description}
      canonical={canonicalUrl}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: `${siteUrl}/og-image.png`,
        },
        optional: {
          description: description,
          siteName: 'Brackstone Digital',
          locale: 'en_GB',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: title,
        description: description,
        image: `${siteUrl}/og-image.png`,
      }}
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <slot />
  </body>
</html>
