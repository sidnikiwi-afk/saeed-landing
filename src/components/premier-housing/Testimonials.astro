---
// Brick & Mortar — testimonials. Real names/roles/services; real client video testimonials.
import listings from '../../data/premier-housing-listings.json';

const testimonialMedia = {
  'Brian Salter': {
    src: 'https://phpropertygroup.co.uk/wp-content/uploads/2022/01/Brian-Salter-Landlord.mp4',
    poster: 'https://phpropertygroup.co.uk/wp-content/uploads/2022/01/video4-screen.webp',
  },
  'Marie Emmott': {
    src: 'https://phpropertygroup.co.uk/wp-content/uploads/2022/01/Marie-Emmott-Landlord.mp4',
    poster: 'https://phpropertygroup.co.uk/wp-content/uploads/2022/01/video1-screen.webp',
  },
  'Rizwana Koser': {
    src: 'https://phpropertygroup.co.uk/wp-content/uploads/2022/01/Rizwana-Koser-Landlord.mp4',
    poster: 'https://phpropertygroup.co.uk/wp-content/uploads/2022/01/video3-screen.webp',
  },
  'Fatima Patel': {
    src: 'https://phpropertygroup.co.uk/wp-content/uploads/2022/01/Fatima-Patel-Tenant.mp4',
    poster: 'https://phpropertygroup.co.uk/wp-content/uploads/2022/01/video2-screen.webp',
  },
};

// Demo note: these videos are hotlinked from the client's site; self-host for production if their URLs may change.
const items = listings.testimonials.map((t) => ({ ...t, media: testimonialMedia[t.name] }));
---
<section class="bm-testi" id="testimonials">
  <div class="bm-testi__inner">
    <header class="bm-testi__head bm-obs">
      <p class="bm-eyebrow5">
        <span class="bm-eyebrow5__rule" aria-hidden="true"></span>
        In their words
      </p>
      <h2 class="bm-testi__title">Trusted by landlords <em>&amp;</em> tenants alike</h2>
    </header>

    <div class="bm-testi__grid">
      {items.map((t, i) => (
        <figure class="bm-quote bm-obs" style={`--i:${i % 2}`}>
          <video
            class="bm-quote__video"
            controls
            preload="none"
            playsinline
            poster={t.media.poster}
            aria-label={`${t.name} testimonial video`}
          >
            <source src={t.media.src} type="video/mp4" />
            Your browser does not support video.
          </video>
          <figcaption class="bm-quote__cap">
            <span class="bm-quote__avatar" aria-hidden="true">{t.name.split(' ').map((n) => n[0]).join('')}</span>
            <span class="bm-quote__who">
              <span class="bm-quote__name">{t.name}</span>
              <span class="bm-quote__role">{t.role} &middot; {t.service}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .bm-testi { background: #EDE6D8; padding: clamp(4.5rem, 8vw, 7rem) 2.25rem; }
  .bm-testi__inner { max-width: 1200px; margin: 0 auto; }
  .bm-testi__head { text-align: center; margin-bottom: 3.2rem; }
  .bm-eyebrow5 {
    display: inline-flex; align-items: center; gap: 0.8rem;
    font-family: 'Work Sans Variable', system-ui, sans-serif;
    font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.26em;
    color: #7C766B; margin: 0 0 0.9rem;
  }
  .bm-eyebrow5__rule { width: 42px; height: 1px; background: #B08D57; }
  .bm-testi__title {
    font-family: 'Cormorant Variable', Georgia, serif;
    font-size: clamp(2.2rem, 4.6vw, 3.6rem); font-weight: 600;
    color: #1F3A2E; margin: 0; letter-spacing: -0.015em;
  }
  .bm-testi__title em { font-style: italic; color: #B08D57; font-weight: 500; }

  .bm-testi__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.6rem;
  }
  .bm-quote {
    position: relative;
    background: #FFFDF8;
    border: 1px solid rgba(176,141,87,0.3);
    border-radius: 4px;
    padding: 1rem 1rem 1.25rem;
    overflow: hidden;
  }
  .bm-quote::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px; background: #B08D57;
  }
  .bm-quote__video {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 9;
    background: #1F3A2E;
    border: 1px solid rgba(176,141,87,0.45);
    border-radius: 4px;
    box-shadow: 0 34px 70px -46px rgba(31,58,46,0.75);
    object-fit: cover;
  }
  .bm-quote__cap { display: flex; align-items: center; gap: 0.9rem; margin-top: 1.05rem; }
  .bm-quote__avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: #1F3A2E; color: #B08D57;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Variable', Georgia, serif;
    font-size: 1.05rem; font-weight: 600; letter-spacing: 0.02em;
    border: 1px solid #B08D57;
    flex: 0 0 auto;
  }
  .bm-quote__who { display: flex; flex-direction: column; }
  .bm-quote__name {
    font-family: 'Work Sans Variable', system-ui, sans-serif;
    font-size: 0.95rem; font-weight: 600; color: #20211C;
  }
  .bm-quote__role {
    font-family: 'Work Sans Variable', system-ui, sans-serif;
    font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; color: #7C766B;
    margin-top: 0.15rem;
  }

  :global(html.bm-anim) .bm-obs { opacity: 0; transform: translateY(26px); transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.22,1,0.36,1); transition-delay: calc(var(--i, 0) * 0.1s); }
  :global(html.bm-anim) .bm-obs.is-in { opacity: 1; transform: translateY(0); }

  @media (max-width: 720px) { .bm-testi__grid { grid-template-columns: 1fr; } }
  @media (prefers-reduced-motion: reduce) { :global(html.bm-anim) .bm-obs { opacity: 1 !important; transform: none !important; } }
</style>
