---
---
<section class="cta-section" id="cta">
  <!-- Inverted lime section -->
  <div class="cta-inner">
    <div class="cta-grid-bg"></div>
    <span class="cta-label">READY?</span>
    <h2 class="cta-headline">
      Stop guessing.<br/>
      Start growing.
    </h2>
    <p class="cta-sub">Book a 15-minute call. We'll look at your business, find where leads are leaking, and tell you exactly what we'd do. No pitch, no pressure. If we're not the right fit, we'll say so.</p>
    <a href="#" class="cta-btn">
      <span>Book a free call</span>
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3.5 9h11M10 4.5l4.5 4.5-4.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="square"/></svg>
    </a>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .cta-section {
    position: relative;
    background: var(--color-brand-primary);
    padding: 6rem 2rem;
    overflow: hidden;
  }

  .cta-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(15, 15, 26, 0.08) 1px, transparent 0);
    background-size: 32px 32px;
    pointer-events: none;
  }

  .cta-inner {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .cta-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: var(--color-brand-bg);
    opacity: 0.5;
    display: block;
    margin-bottom: 1.5rem;
  }

  .cta-headline {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-brand-bg);
    margin: 0 0 1.5rem;
  }

  .cta-sub {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.7;
    color: rgba(15, 15, 26, 0.7);
    margin: 0 0 2.5rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.1rem 2.5rem;
    background: var(--color-brand-bg);
    color: var(--color-brand-primary);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    clip-path: polygon(0 0, 100% 0, 100% 65%, 88% 100%, 0 100%);
    transition: box-shadow 0.3s, transform 0.2s;
  }

  .cta-btn:hover {
    box-shadow: 0 0 40px rgba(15, 15, 26, 0.3);
    transform: translateY(-2px) scale(1.02);
  }

  @media (max-width: 768px) {
    .cta-section { padding: 4rem 1.25rem; }
  }
</style>
