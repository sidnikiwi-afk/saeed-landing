---
---
<section class="cta-section" id="cta">
  <div class="cta-card">
    <div class="cta-bg" aria-hidden="true"></div>
    <div class="cta-content">
      <span class="cta-eyebrow">Ready when you are</span>
      <h2 class="cta-headline">See Brackstone handle a real call.</h2>
      <p class="cta-sub">
        Ask for a sample, or book a 15-minute walkthrough. We will show you the dashboard,
        the kind of calls it handles, and whether it fits the way your team works today.
      </p>
      <div class="cta-row">
        <a href="/contact" class="cta-primary">
          Book a walkthrough
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/contact" class="cta-secondary">Talk to us first</a>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .cta-section {
    background: var(--color-brand-bg);
    padding: 4rem 1.5rem 5rem;
  }

  .cta-card {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    border-radius: 28px;
    padding: 4rem 2rem;
    background: linear-gradient(135deg, #14102B 0%, #1F1640 50%, #2A1A5E 100%);
    overflow: hidden;
    isolation: isolate;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(40% 60% at 20% 30%, rgba(110, 72, 240, 0.4), transparent 70%),
      radial-gradient(35% 50% at 85% 70%, rgba(0, 200, 150, 0.25), transparent 70%);
    z-index: -1;
  }

  .cta-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(70% 60% at 50% 50%, #000, transparent 80%);
    -webkit-mask-image: radial-gradient(70% 60% at 50% 50%, #000, transparent 80%);
  }

  .cta-content {
    position: relative;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #C7B8FF;
    margin-bottom: 0.85rem;
  }

  .cta-headline {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.05;
    letter-spacing: 0;
    color: #fff;
    margin: 0 0 1rem;
  }

  .cta-sub {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.72);
    margin: 0 0 2rem;
  }

  .cta-row {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.5rem;
    background: #fff;
    color: var(--color-brand-ink);
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.98rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 30px -10px rgba(255, 255, 255, 0.35);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.5rem;
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.98rem;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .cta-secondary:hover {
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 720px) {
    .cta-card { padding: 3rem 1.2rem; border-radius: 22px; }
    .cta-section { padding: 3rem 1rem; }
    .cta-primary, .cta-secondary { width: 100%; justify-content: center; }
  }
</style>
