---
const steps = [
  {
    n: '01',
    title: 'Brackstone answers the call',
    body: 'A calm, natural voice picks up on the first ring, day or night. Callers never hit voicemail or a busy tone.',
  },
  {
    n: '02',
    title: 'It qualifies the enquiry',
    body: 'Asks the right questions for your business, captures contact details, and identifies what is urgent vs. routine.',
  },
  {
    n: '03',
    title: 'You see it in the dashboard',
    body: 'Every call is transcribed, summarised, and sorted by priority. Follow-ups stay visible until they are handled.',
  },
];
---
<section class="how" id="how">
  <div class="how-inner">
    <header class="how-head">
      <span class="how-eyebrow">How it works</span>
      <h2 class="how-title">A receptionist that never has a busy day.</h2>
      <p class="how-sub">Setup takes a week. After that, Brackstone runs in the background while your team focuses on the customers in front of them.</p>
    </header>

    <ol class="steps">
      {steps.map((s) => (
        <li class="step">
          <span class="step-n">{s.n}</span>
          <h3 class="step-title">{s.title}</h3>
          <p class="step-body">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .how {
    background: var(--color-brand-bg);
    padding: 5rem 1.5rem 4rem;
  }

  .how-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .how-head {
    max-width: 680px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .how-eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-brand-primary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
  }

  .how-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.85rem, 3.6vw, 2.6rem);
    line-height: 1.1;
    letter-spacing: 0;
    color: var(--color-brand-ink);
    margin: 0 0 0.85rem;
  }

  .how-sub {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--color-brand-muted);
    margin: 0;
  }

  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .step {
    position: relative;
    background: #fff;
    border: 1px solid var(--color-brand-line);
    border-radius: 18px;
    padding: 1.6rem 1.4rem 1.8rem;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .step:hover {
    border-color: rgba(110, 72, 240, 0.35);
    transform: translateY(-2px);
    box-shadow: 0 14px 30px -18px rgba(110, 72, 240, 0.35);
  }

  .step-n {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-brand-primary);
    background: rgba(110, 72, 240, 0.08);
    border: 1px solid rgba(110, 72, 240, 0.18);
    border-radius: 8px;
    padding: 0.25rem 0.55rem;
    margin-bottom: 1rem;
  }

  .step-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0;
    color: var(--color-brand-ink);
    margin: 0 0 0.5rem;
  }

  .step-body {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-brand-muted);
    margin: 0;
  }

  @media (max-width: 820px) {
    .steps { grid-template-columns: 1fr; }
    .how { padding: 4rem 1.1rem 3rem; }
  }
</style>
