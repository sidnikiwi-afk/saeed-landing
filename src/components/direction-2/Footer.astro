---
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <a href="/" class="footer-logo" aria-label="Brackstone home">
        <span class="f-logo-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="2" y="2" width="20" height="20" rx="6" fill="currentColor"/>
            <path d="M8 7.5h5.2c1.7 0 2.9 1 2.9 2.4 0 1-.6 1.7-1.5 2 1.1.3 1.8 1.2 1.8 2.4 0 1.6-1.2 2.7-3.1 2.7H8V7.5Zm2.1 3.6h2.7c.8 0 1.3-.4 1.3-1s-.5-1-1.3-1h-2.7v2Zm0 4h2.9c.9 0 1.4-.4 1.4-1.1 0-.7-.5-1.1-1.4-1.1h-2.9v2.2Z" fill="#fff"/>
          </svg>
        </span>
        <span class="f-logo-text">Brackstone</span>
      </a>
      <p class="footer-tagline">A calmer phone line for small UK teams.</p>
    </div>
    <div class="footer-right">
      <div class="footer-col">
        <span class="footer-col-label">Product</span>
        <a href="#voice-ai">Voice AI</a>
        <a href="#dashboard">Dashboard</a>
        <a href="#how">How it works</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Company</span>
        <a href="/contact">Get in touch</a>
        <a href="/privacy">Privacy</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span>&copy; 2026 Brackstone Digital. All rights reserved.</span>
    <span style="display:block;margin-top:0.5rem;font-size:0.72rem;opacity:0.55;line-height:1.5;">Brackstone Digital Limited, registered in England &amp; Wales, company no. 17159711. Registered office: 71-75 Shelton Street, Covent Garden, London, WC2H 9JQ.</span>
  </div>
</footer>

<style>
  @reference "../../styles/global.css";

  .footer {
    background: var(--color-brand-bg);
    padding: 3rem 1.5rem 1.75rem;
    border-top: 1px solid var(--color-brand-line);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-brand-line);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    margin-bottom: 0.5rem;
  }

  .f-logo-mark {
    display: inline-flex;
    color: var(--color-brand-primary);
  }

  .f-logo-text {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.98rem;
    color: var(--color-brand-ink);
    letter-spacing: 0;
  }

  .footer-tagline {
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-brand-muted);
    margin: 0;
    max-width: 280px;
  }

  .footer-right {
    display: flex;
    gap: 3rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .footer-col-label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-brand-ink);
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }

  .footer-col a {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-brand-muted);
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .footer-col a:hover {
    color: var(--color-brand-ink);
  }

  .footer-bottom {
    max-width: 1100px;
    margin: 0 auto;
    padding-top: 1.25rem;
  }

  .footer-bottom span {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--color-brand-muted);
  }

  @media (max-width: 720px) {
    .footer-inner { flex-direction: column; gap: 2rem; }
    .footer-right { gap: 2rem; }
    .footer { padding: 2.5rem 1.1rem 1.5rem; }
  }
</style>
