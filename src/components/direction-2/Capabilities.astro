---
---
<section class="cap" id="capabilities">
  <div class="cap-inner">
    <span class="section-label">CAPABILITIES</span>
    <h2 class="cap-title">Four engines. One system.</h2>
    <p class="cap-sub">Each service feeds the next. Outreach fills your pipeline. Voice AI catches every call. Your site converts visitors. Ads amplify everything. It's not four services. It's one machine.</p>

    <div class="bento">
      <!-- Large card: Outreach -->
      <div class="bento-card card-outreach">
        <div class="card-glow"></div>
        <div class="card-content">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M3 7l11 7 11-7M3 7v14l11 7 11-7V7M3 7l11-4 11 4" stroke="currentColor" stroke-width="1.5"/></svg>
          </div>
          <span class="card-label">OUTREACH</span>
          <h3 class="card-name">Cold email that<br/>opens doors</h3>
          <p class="card-desc">Personalised B2B campaigns that land in inboxes, not spam. We handle list building, copy, sending, and follow-ups. You just take the meetings.</p>
          <div class="card-stats">
            <div class="stat">
              <span class="stat-val">300+</span>
              <span class="stat-label">prospects/month</span>
            </div>
            <div class="stat">
              <span class="stat-val">40%+</span>
              <span class="stat-label">open rates</span>
            </div>
          </div>
        </div>
        <div class="circuit-lines">
          <div class="c-line c-1"></div>
          <div class="c-line c-2"></div>
          <div class="c-line c-3"></div>
        </div>
      </div>

      <!-- Voice AI -->
      <div class="bento-card card-voice">
        <div class="card-glow"></div>
        <div class="card-content">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="10" y="2" width="8" height="14" rx="4" stroke="currentColor" stroke-width="1.5"/><path d="M6 12a8 8 0 0016 0M14 22v4M10 26h8" stroke="currentColor" stroke-width="1.5"/></svg>
          </div>
          <span class="card-label">VOICE AI</span>
          <h3 class="card-name">Never miss<br/>a call again</h3>
          <p class="card-desc">An AI receptionist that answers 24/7, qualifies callers, and books appointments. Sounds human. Works all night.</p>
        </div>
        <div class="circuit-lines">
          <div class="c-line c-4"></div>
        </div>
      </div>

      <!-- Websites -->
      <div class="bento-card card-web">
        <div class="card-glow"></div>
        <div class="card-content">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="2" y="4" width="24" height="18" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h24" stroke="currentColor" stroke-width="1.5"/><circle cx="5.5" cy="7" r="1" fill="currentColor"/><circle cx="8.5" cy="7" r="1" fill="currentColor"/></svg>
          </div>
          <span class="card-label">WEBSITES</span>
          <h3 class="card-name">Sites that sell</h3>
          <p class="card-desc">Fast, conversion-focused sites built to turn visitors into leads. Not a brochure. A sales machine.</p>
        </div>
        <div class="circuit-lines">
          <div class="c-line c-5"></div>
        </div>
      </div>

      <!-- Paid Ads - inverted lime section -->
      <div class="bento-card card-ads inverted">
        <div class="card-content">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 2v24M2 14h24M7 7l14 14M21 7L7 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
          </div>
          <span class="card-label">PAID ADS</span>
          <h3 class="card-name">Targeted spend,<br/>real returns</h3>
          <p class="card-desc">Google and Meta ads managed by people who hate wasting money as much as you do. Every pound tracked.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="cap-angle"></div>
</section>

<style>
  @reference "../../styles/global.css";

  .cap {
    position: relative;
    background: var(--color-brand-bg);
    padding: 6rem 2rem 8rem;
  }

  .cap-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: var(--color-brand-primary);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    padding: 0.35rem 1rem;
    border: 1px solid rgba(191, 255, 0, 0.25);
  }

  .cap-title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(2rem, 4.5vw, 3rem);
    letter-spacing: -0.03em;
    color: var(--color-brand-text);
    margin: 0 0 1rem;
  }

  .cap-sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-brand-muted);
    max-width: 600px;
    margin: 0 0 3.5rem;
  }

  .bento {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    grid-template-rows: auto auto;
    gap: 1.25rem;
  }

  .bento-card {
    position: relative;
    background: var(--color-brand-surface);
    border: 1px solid rgba(191, 255, 0, 0.06);
    padding: 2.5rem;
    overflow: hidden;
    transition: border-color 0.4s, box-shadow 0.4s;
  }

  .bento-card:hover {
    border-color: rgba(191, 255, 0, 0.2);
  }

  .card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at 30% 30%, rgba(191, 255, 0, 0.04), transparent 50%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }

  .bento-card:hover .card-glow {
    opacity: 1;
  }

  .card-content {
    position: relative;
    z-index: 2;
  }

  .card-icon {
    color: var(--color-brand-primary);
    margin-bottom: 1.5rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(191, 255, 0, 0.15);
  }

  .card-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: var(--color-brand-primary);
    opacity: 0.6;
  }

  .card-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-brand-text);
    margin: 0.5rem 0 0.75rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .card-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-brand-muted);
    margin: 0;
  }

  /* Outreach spans full width on first row concept - actually let it be big left */
  .card-outreach {
    grid-row: 1 / 3;
  }

  .card-stats {
    display: flex;
    gap: 2rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(191, 255, 0, 0.08);
  }

  .stat-val {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--color-brand-primary);
    display: block;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-brand-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Inverted card (lime bg) */
  .inverted {
    background: var(--color-brand-primary) !important;
    border-color: var(--color-brand-primary) !important;
  }

  .inverted .card-icon {
    color: var(--color-brand-bg);
    border-color: rgba(15, 15, 26, 0.2);
  }

  .inverted .card-label {
    color: var(--color-brand-bg);
    opacity: 0.7;
  }

  .inverted .card-name {
    color: var(--color-brand-bg);
  }

  .inverted .card-desc {
    color: rgba(15, 15, 26, 0.7);
  }

  .inverted:hover {
    box-shadow: 0 0 40px rgba(191, 255, 0, 0.3);
  }

  /* Circuit board lines motif */
  .circuit-lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .c-line {
    position: absolute;
    background: rgba(191, 255, 0, 0.06);
  }

  .c-1 {
    width: 1px;
    height: 60%;
    right: 30%;
    bottom: 0;
  }

  .c-2 {
    width: 40%;
    height: 1px;
    right: 0;
    top: 40%;
  }

  .c-3 {
    width: 1px;
    height: 30%;
    right: 30%;
    top: 40%;
  }

  .c-4 {
    width: 60%;
    height: 1px;
    left: 0;
    bottom: 30%;
  }

  .c-5 {
    width: 1px;
    height: 50%;
    left: 40%;
    top: 0;
  }

  .bento-card:hover .c-line {
    background: rgba(191, 255, 0, 0.12);
    box-shadow: 0 0 4px rgba(191, 255, 0, 0.1);
  }

  .cap-angle {
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 80px;
    background: var(--color-brand-primary);
    clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }

  @media (max-width: 768px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .card-outreach {
      grid-row: auto;
    }
    .cap { padding: 4rem 1.25rem 6rem; }
    .bento-card { padding: 2rem; }
  }
</style>
