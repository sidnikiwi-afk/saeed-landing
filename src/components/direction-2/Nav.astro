---
---
<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Brackstone home">
      <span class="logo-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="2" width="20" height="20" rx="6" fill="currentColor"/>
          <path d="M8 7.5h5.2c1.7 0 2.9 1 2.9 2.4 0 1-.6 1.7-1.5 2 1.1.3 1.8 1.2 1.8 2.4 0 1.6-1.2 2.7-3.1 2.7H8V7.5Zm2.1 3.6h2.7c.8 0 1.3-.4 1.3-1s-.5-1-1.3-1h-2.7v2Zm0 4h2.9c.9 0 1.4-.4 1.4-1.1 0-.7-.5-1.1-1.4-1.1h-2.9v2.2Z" fill="#fff"/>
        </svg>
      </span>
      <span class="logo-text">Brackstone</span>
    </a>
    <div class="nav-links">
      <a href="#how">How it works</a>
      <a href="#voice-ai">Voice AI</a>
      <a href="#dashboard">Dashboard</a>
      <a href="/contact" class="nav-cta">Get in touch</a>
    </div>
    <button class="mobile-toggle" id="mobile-toggle" aria-label="Menu">
      <span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <a href="#how" class="mobile-link">How it works</a>
  <a href="#voice-ai" class="mobile-link">Voice AI</a>
  <a href="#dashboard" class="mobile-link">Dashboard</a>
  <a href="/contact" class="mobile-cta">Get in touch</a>
</div>

<style>
  @reference "../../styles/global.css";

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 2rem;
    transition: background 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    border-bottom: 1px solid transparent;
    background: rgba(247, 247, 248, 0);
  }

  .nav.scrolled {
    background: rgba(247, 247, 248, 0.85);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--color-brand-line);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-primary);
  }

  .logo-text {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-brand-ink);
    letter-spacing: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-brand-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.18s ease;
  }

  .nav-links a:hover {
    color: var(--color-brand-ink);
  }

  .nav-cta {
    padding: 0.55rem 1.1rem !important;
    background: var(--color-brand-ink) !important;
    color: #fff !important;
    border-radius: 999px;
    font-weight: 600 !important;
    transition: background 0.18s ease, transform 0.18s ease;
  }

  .nav-cta:hover {
    background: var(--color-brand-primary) !important;
    color: #fff !important;
    transform: translateY(-1px);
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
  }

  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-brand-ink);
    border-radius: 2px;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 72px;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(14px);
    padding: 1.5rem;
    flex-direction: column;
    gap: 1rem;
    z-index: 99;
    border-bottom: 1px solid var(--color-brand-line);
  }

  .mobile-menu.open { display: flex; }

  .mobile-link {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-brand-ink);
    text-decoration: none;
    font-weight: 500;
  }

  .mobile-cta {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-brand-ink);
    color: #fff;
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
    text-align: center;
    width: fit-content;
  }

  @media (max-width: 820px) {
    .nav-links { display: none; }
    .mobile-toggle { display: flex; }
    .nav { padding: 0 1.25rem; }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 16);
  });

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('open');
  });

  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => menu?.classList.remove('open'));
  });
</script>
