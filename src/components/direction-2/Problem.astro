---
const problems = [
  {
    number: "01",
    title: "You're invisible online",
    desc: "Your competitors show up everywhere. You rely on word of mouth and hope. That's not a strategy, it's a gamble.",
  },
  {
    number: "02",
    title: "You're juggling too many tools",
    desc: "A web guy, an ads person, a CRM you barely use. Nothing talks to each other and you're the glue holding it together.",
  },
  {
    number: "03",
    title: "Leads fall through the cracks",
    desc: "Missed calls, slow follow-ups, no system. By the time you reply, they've already gone to the other lot down the road.",
  },
  {
    number: "04",
    title: "Marketing feels like a money pit",
    desc: "You've tried agencies before. Fancy decks, vague reports, no real results. You need outcomes, not overhead.",
  },
];
---

<section class="problem" id="problem">
  <div class="problem-inner">
    <div class="problem-header">
      <span class="section-label">THE PROBLEM</span>
      <h2 class="problem-title">
        Small businesses don't need more marketing.
        <span class="accent-text">They need a system that works.</span>
      </h2>
    </div>

    <div class="problem-grid">
      {problems.map((p, i) => (
        <div class="problem-card" style={`--delay: ${i * 0.1}s`}>
          <div class="card-edge"></div>
          <span class="card-number">{p.number}</span>
          <h3 class="card-title">{p.title}</h3>
          <p class="card-desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Angled divider bottom -->
  <div class="problem-angle"></div>
</section>

<style>
  @reference "../../styles/global.css";

  .problem {
    position: relative;
    background: var(--color-brand-surface);
    padding: 6rem 2rem 8rem;
  }

  .problem-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: var(--color-brand-primary);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    padding: 0.35rem 1rem;
    border: 1px solid rgba(191, 255, 0, 0.25);
  }

  .problem-title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-brand-text);
    max-width: 650px;
    margin: 0 0 3.5rem;
  }

  .accent-text {
    color: var(--color-brand-primary);
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .problem-card {
    position: relative;
    background: var(--color-brand-bg);
    padding: 2rem 2rem 2rem 2.5rem;
    border: 1px solid rgba(191, 255, 0, 0.06);
    transition: border-color 0.3s, box-shadow 0.3s;
    overflow: hidden;
  }

  .problem-card:hover {
    border-color: rgba(191, 255, 0, 0.2);
    box-shadow: 0 0 30px rgba(191, 255, 0, 0.05);
  }

  .card-edge {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(180deg, var(--color-brand-primary), var(--color-brand-accent));
    opacity: 0.4;
    transition: opacity 0.3s;
  }

  .problem-card:hover .card-edge {
    opacity: 1;
    box-shadow: 0 0 12px rgba(191, 255, 0, 0.3);
  }

  .card-number {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.8rem;
    color: var(--color-brand-primary);
    letter-spacing: 0.1em;
    opacity: 0.5;
  }

  .card-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-brand-text);
    margin: 0.75rem 0 0.6rem;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-brand-muted);
    margin: 0;
  }

  .problem-angle {
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 80px;
    background: #16213E;
    clip-path: polygon(0 60%, 100% 100%, 0 100%);
  }

  @media (max-width: 768px) {
    .problem-grid { grid-template-columns: 1fr; }
    .problem { padding: 4rem 1.25rem 6rem; }
  }
</style>
