---
---
<section class="hero">
  <div class="hero-bg" aria-hidden="true"></div>

  <div class="hero-inner">
    <div class="hero-eyebrow">
      <span class="dot" aria-hidden="true"></span>
      <span>Voice AI for small UK teams</span>
    </div>

    <h1 class="hero-headline">
      Every caller gets a
      <span class="grad">calm first response.</span>
    </h1>

    <p class="hero-sub">
      Brackstone answers, qualifies and organises enquiries for small teams, so urgent
      follow-ups and bookings stay visible without extra admin.
    </p>

    <div class="hero-cta-row">
      <a href="/contact" class="btn-primary">
        Book a walkthrough
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/contact" class="btn-ghost">Talk to us</a>
    </div>

    <div class="hero-meta">
      <span class="meta-pill"><span class="meta-dot"></span> Answers in under 2 seconds</span>
      <span class="meta-sep" aria-hidden="true">·</span>
      <span class="meta-pill">UK timezones &amp; phone numbers</span>
      <span class="meta-sep" aria-hidden="true">·</span>
      <span class="meta-pill">Hands off after setup</span>
    </div>
  </div>

  <div class="hero-shot" aria-hidden="true">
    <div class="shot-frame">
      <div class="shot-chrome">
        <span class="chrome-dot"></span>
        <span class="chrome-dot"></span>
        <span class="chrome-dot"></span>
        <span class="chrome-url">brackstone.app</span>
      </div>
      <img src="/images/homepage/dashboard-overview-1440x900.png" alt="" loading="eager" decoding="async" />
    </div>
    <div class="shot-glow"></div>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .hero {
    position: relative;
    padding: 9rem 1.5rem 4rem;
    overflow: hidden;
    background: var(--color-brand-bg);
  }

  .hero-bg {
    position: absolute;
    inset: -10% -5% 0 -5%;
    background:
      radial-gradient(60% 50% at 50% 0%, rgba(110, 72, 240, 0.16), transparent 70%),
      radial-gradient(45% 40% at 85% 30%, rgba(0, 200, 150, 0.08), transparent 70%);
    pointer-events: none;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(var(--color-brand-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-brand-line) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(70% 60% at 50% 30%, #000 0%, transparent 75%);
    -webkit-mask-image: radial-gradient(70% 60% at 50% 30%, #000 0%, transparent 75%);
    opacity: 0.5;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.85rem;
    background: rgba(110, 72, 240, 0.08);
    color: var(--color-brand-primary);
    border: 1px solid rgba(110, 72, 240, 0.18);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    margin-bottom: 1.5rem;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand-primary);
    box-shadow: 0 0 0 3px rgba(110, 72, 240, 0.18);
  }

  .hero-headline {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(2.4rem, 6vw, 4.4rem);
    line-height: 1.04;
    letter-spacing: 0;
    color: var(--color-brand-ink);
    margin: 0 auto 1.25rem;
    max-width: 780px;
  }

  .grad {
    background: linear-gradient(120deg, var(--color-brand-primary) 0%, #8C6BFF 60%, var(--color-brand-accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(1.02rem, 1.5vw, 1.18rem);
    line-height: 1.6;
    color: var(--color-brand-muted);
    max-width: 620px;
    margin: 0 auto 2rem;
  }

  .hero-cta-row {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 1.75rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.4rem;
    background: var(--color-brand-ink);
    color: #fff;
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.98rem;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 1px 0 rgba(255,255,255,0.06) inset, 0 8px 24px -10px rgba(10,10,11,0.4);
  }

  .btn-primary:hover {
    background: var(--color-brand-primary);
    transform: translateY(-1px);
    box-shadow: 0 12px 30px -10px rgba(110, 72, 240, 0.5);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.4rem;
    background: transparent;
    color: var(--color-brand-ink);
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.98rem;
    text-decoration: none;
    border: 1px solid var(--color-brand-line);
    background: #fff;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .btn-ghost:hover {
    border-color: var(--color-brand-ink);
  }

  .hero-meta {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    color: var(--color-brand-muted);
    font-size: 0.82rem;
  }

  .meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .meta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand-accent);
  }

  .meta-sep { opacity: 0.5; }

  .hero-shot {
    position: relative;
    max-width: 1100px;
    margin: 3.5rem auto 0;
    padding: 0 1rem;
    z-index: 2;
  }

  .shot-frame {
    position: relative;
    border-radius: 16px;
    background: #fff;
    border: 1px solid var(--color-brand-line);
    overflow: hidden;
    box-shadow:
      0 1px 0 #fff inset,
      0 30px 60px -25px rgba(10, 10, 11, 0.25),
      0 12px 30px -15px rgba(110, 72, 240, 0.25);
  }

  .shot-chrome {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid var(--color-brand-line);
    background: #FAFAFB;
  }

  .chrome-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #E0E0E5;
  }

  .chrome-dot:nth-child(1) { background: #FF6058; }
  .chrome-dot:nth-child(2) { background: #FFBD2D; }
  .chrome-dot:nth-child(3) { background: #28C940; }

  .chrome-url {
    margin-left: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-brand-muted);
  }

  .shot-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .shot-glow {
    position: absolute;
    inset: -10% -5% -20%;
    background: radial-gradient(50% 40% at 50% 0%, rgba(110, 72, 240, 0.18), transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  @media (max-width: 720px) {
    .hero { padding: 7rem 1.1rem 3rem; }
    .hero-cta-row { width: 100%; }
    .btn-primary, .btn-ghost { width: 100%; justify-content: center; }
    .hero-meta { font-size: 0.78rem; }
    .meta-sep { display: none; }
    .hero-shot { margin-top: 2.5rem; }
    .chrome-url { display: none; }
  }
</style>
