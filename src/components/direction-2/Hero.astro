---
---
<section class="hero">
  <!-- Grid dot background -->
  <div class="grid-bg"></div>
  <!-- Scan line -->
  <div class="scan-line"></div>

  <div class="hero-inner">
    <div class="hero-label">
      <span class="label-dot"></span>
      <span>FULL-STACK GROWTH PARTNER</span>
    </div>

    <h1 class="hero-headline">
      <span class="line line-1">Your business</span>
      <span class="line line-2">deserves a</span>
      <span class="line line-3 gradient-text">growth engine.</span>
    </h1>

    <p class="hero-sub">
      Cold email outreach. AI voice agents. High-converting websites. Paid ads.
      One team, one system, one partner who actually gives a damn.
    </p>

    <div class="hero-cta-row">
      <a href="#cta" class="hero-btn">
        <span>Book a free call</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="square"/></svg>
      </a>
      <span class="hero-note">15 minutes. No pitch. Just a plan.</span>
    </div>
  </div>

  <!-- Angled divider -->
  <div class="hero-angle"></div>
</section>

<style>
  @reference "../../styles/global.css";

  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 6rem;
    overflow: hidden;
    background: var(--color-brand-bg);
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(191, 255, 0, 0.07) 1px, transparent 0);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .scan-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-brand-primary), var(--color-brand-accent), transparent);
    opacity: 0.5;
    animation: scanDown 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes scanDown {
    0% { top: 0; opacity: 0; }
    10% { opacity: 0.5; }
    90% { opacity: 0.5; }
    100% { top: 100%; opacity: 0; }
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--color-brand-primary);
    text-transform: uppercase;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.2s forwards;
  }

  .label-dot {
    width: 8px;
    height: 8px;
    background: var(--color-brand-primary);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(191, 255, 0, 0.4); }
    50% { box-shadow: 0 0 0 6px rgba(191, 255, 0, 0); }
  }

  .hero-headline {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-brand-text);
    margin: 0 0 2rem;
  }

  .line {
    display: block;
    opacity: 0;
    transform: translateY(40px);
  }

  .line-1 { animation: lineReveal 0.7s 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .line-2 { animation: lineReveal 0.7s 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .line-3 { animation: lineReveal 0.7s 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; }

  @keyframes lineReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-brand-primary) 0%, var(--color-brand-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.7;
    color: var(--color-brand-muted);
    max-width: 560px;
    margin: 0 0 2.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.8s forwards;
  }

  .hero-cta-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.6s 1s forwards;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: var(--color-brand-primary);
    color: var(--color-brand-bg);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    clip-path: polygon(0 0, 100% 0, 100% 65%, 88% 100%, 0 100%);
    transition: box-shadow 0.3s, transform 0.2s;
    position: relative;
  }

  .hero-btn:hover {
    box-shadow: 0 0 30px rgba(191, 255, 0, 0.5), 0 0 60px rgba(191, 255, 0, 0.2);
    transform: translateY(-2px);
  }

  .hero-note {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-brand-muted);
    font-style: italic;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-angle {
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 80px;
    background: var(--color-brand-surface);
    clip-path: polygon(0 100%, 100% 40%, 100% 100%);
  }

  @media (max-width: 768px) {
    .hero { padding: 7rem 1.25rem 5rem; }
    .hero-headline { letter-spacing: -0.03em; }
    .hero-cta-row { flex-direction: column; align-items: flex-start; }
  }
</style>
