---
import Layout from '../layouts/Layout.astro';
import { Schema } from 'astro-seo-schema';
import Nav from '../components/direction-2/Nav.astro';
import Hero from '../components/direction-2/Hero.astro';
import Trust from '../components/direction-2/Trust.astro';
import HowItWorks from '../components/direction-2/HowItWorks.astro';
import VoiceAI from '../components/direction-2/VoiceAI.astro';
import DashboardProof from '../components/direction-2/DashboardProof.astro';
import Testimonial from '../components/direction-2/Testimonial.astro';
import Cta from '../components/direction-2/Cta.astro';
import Footer from '../components/direction-2/Footer.astro';
---

<Layout
  title="Brackstone - Voice AI receptionist for UK small teams"
  description="Brackstone answers, qualifies and organises enquiries for small teams, so urgent follow-ups and bookings stay visible without extra admin."
>
  <style is:global>
    html { scroll-behavior: smooth; }

    body {
      background: var(--color-brand-bg) !important;
      color: var(--color-brand-text) !important;
      font-family: var(--font-body) !important;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading) !important;
    }

    ::selection {
      background: var(--color-brand-primary);
      color: #fff;
    }

    .sr {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sr.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <Nav />
  <Hero />
  <Trust />
  <HowItWorks />
  <VoiceAI />
  <DashboardProof />
  <Testimonial />
  <Cta />
  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.step, .panel, .va-card, .va-list li, .trust-item, .quote-body').forEach((el) => {
      el.classList.add('sr');
      observer.observe(el);
    });

    document.querySelectorAll('.step').forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 0.08}s`;
    });
    document.querySelectorAll('.trust-item').forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 0.05}s`;
    });
  </script>

  <Schema
    item={{
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Brackstone Digital",
      "url": "https://brackstonedigital.co.uk",
      "description": "Voice AI receptionist that answers, qualifies and organises enquiries for small UK teams.",
      "areaServed": {
        "@type": "Country",
        "name": "United Kingdom"
      },
      "serviceType": ["Voice AI", "AI Receptionist", "Call Handling", "Lead Qualification"],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "sales",
        "email": "hello@brackstonedigital.co.uk",
        "url": "https://brackstonedigital.co.uk/contact"
      }
    }}
  />
</Layout>
