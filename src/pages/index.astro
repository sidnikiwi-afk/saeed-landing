---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/direction-2/Nav.astro';
import Hero from '../components/direction-2/Hero.astro';
import Problem from '../components/direction-2/Problem.astro';
import HowItWorks from '../components/direction-2/HowItWorks.astro';
import Capabilities from '../components/direction-2/Capabilities.astro';
import Cta from '../components/direction-2/Cta.astro';
import Footer from '../components/direction-2/Footer.astro';
---

<Layout title="Brackstone Digital — Full-Stack Growth for UK Businesses" description="Cold email, voice AI, websites, paid ads — one partner, one system. We help small businesses get more customers.">
  <style is:global>
    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--color-brand-bg) !important;
      color: var(--color-brand-text) !important;
      font-family: var(--font-body) !important;
      overflow-x: hidden;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading) !important;
    }

    ::selection {
      background: var(--color-brand-primary);
      color: var(--color-brand-bg);
    }

    .sr {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sr.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <Nav />
  <Hero />
  <Problem />
  <HowItWorks />
  <Capabilities />
  <Cta />
  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.problem-card, .step, .bento-card, .cap-title, .cap-sub').forEach((el) => {
      el.classList.add('sr');
      observer.observe(el);
    });

    document.querySelectorAll('.problem-card').forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 0.1}s`;
    });
    document.querySelectorAll('.step').forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 0.15}s`;
    });
    document.querySelectorAll('.bento-card').forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 0.1}s`;
    });
  </script>
</Layout>
