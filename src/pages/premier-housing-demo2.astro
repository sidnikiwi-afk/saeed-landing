---
const endpoint = 'https://premier-housing-demo.pages.dev/api/enquire';
const pageUrl = 'https://brackstonedigital.co.uk/premier-housing-demo2/';

// Exactly one synthetic listing. No real address, photos, portal data, or people.
const listing = {
  title: '2 bedroom apartment, Premier House, Bradford BD1',
  price: '£725 pcm',
  priceNote: '£167 pw · Tenancy available now',
  type: 'Apartment · Leasehold',
  beds: 2,
  baths: 1,
  receptions: 1,
  size: '742 sq ft',
  epc: 'C',
  council: 'Band A',
  added: 'Listed 3 days ago',
  agent: 'Premier Housing Lettings (synthetic demo branch)',
};

const galleryShots = [
  'Reception room',
  'Kitchen',
  'Main bedroom',
  'Bathroom',
  'Floor plan',
];

const features = [
  'Two double bedrooms',
  'Open-plan living / kitchen',
  'Allocated parking space',
  'Double glazing throughout',
  'Gas central heating',
  'Within walking distance of the city centre',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Premier Housing Synthetic Portal Demo</title>
    <meta
      name="description"
      content="Synthetic Premier Housing portal-style enquiry demo page for controlled Brackstone testing only."
    />
    <link rel="canonical" href={pageUrl} />
  </head>
  <body data-enquire-endpoint={endpoint}>
    <!-- Persistent demo disclaimer (exact wording must be preserved) -->
    <div class="disclaimer" role="note">
      <strong>Demo-only page.</strong>
      <span>Synthetic portal demo, not affiliated with Zoopla.</span>
    </div>

    <!-- Portal-style purple top bar -->
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="#" aria-label="Premier Housing demo home">
          <span class="brand-mark" aria-hidden="true">PH</span>
          <span class="brand-name">Premier Housing</span>
        </a>
        <nav class="topnav" aria-label="Demo navigation">
          <span>Buy</span>
          <span>Rent</span>
          <span>Sold prices</span>
          <span>Find agents</span>
          <span>House prices</span>
        </nav>
        <div class="topbar-actions">
          <span class="topbar-link" aria-hidden="true">Saved</span>
          <span class="topbar-link" aria-hidden="true">Sign in</span>
          <button type="button" class="btn btn-primary topbar-cta" data-open-form>Get evaluation</button>
        </div>
      </div>
    </header>

    <main class="portal">
      <!-- Synthetic search bar mockup (non-functional, illustrative only) -->
      <section class="searchbar" aria-label="Synthetic search (demo only)">
        <div class="search-field">
          <span class="search-label">Location</span>
          <span class="search-value">Bradford, BD1</span>
        </div>
        <div class="search-field">
          <span class="search-label">Search type</span>
          <span class="search-value">Homes to rent</span>
        </div>
        <div class="search-field">
          <span class="search-label">Beds</span>
          <span class="search-value">2+</span>
        </div>
        <span class="search-go btn btn-accent" aria-hidden="true">Search</span>
      </section>

      <nav class="breadcrumb" aria-label="Breadcrumb">
        <span>Rent</span>
        <span aria-hidden="true">›</span>
        <span>Bradford</span>
        <span aria-hidden="true">›</span>
        <span>BD1</span>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Premier House (demo)</span>
      </nav>

      <!-- CSS-only synthetic gallery: one large left image + smaller right tiles. No external images. -->
      <section class="gallery" aria-label="Synthetic property gallery (placeholder images)">
        <figure class="gallery-main shot shot-hero" aria-hidden="true">
          <span class="shot-label">Reception room</span>
          <span class="shot-count">1 / {galleryShots.length} · synthetic placeholders</span>
        </figure>
        <div class="gallery-side" aria-hidden="true">
          {galleryShots.slice(1).map((label, i) => (
            <figure class={`shot thumb shot-${i + 1}`}>
              <span class="shot-label">{label}</span>
              {i === galleryShots.slice(1).length - 1 && (
                <span class="shot-more">+ gallery</span>
              )}
            </figure>
          ))}
        </div>
      </section>

      <div class="layout">
        <article class="detail">
          <!-- Primary listing card -->
          <div class="card listing-head">
            <div class="badges">
              <span class="badge badge-accent">Synthetic listing</span>
              <span class="badge">{listing.added}</span>
            </div>

            <p class="price">{listing.price}</p>
            <p class="price-note">{listing.priceNote}</p>
            <h1 class="listing-title">{listing.title}</h1>
            <p class="listing-type">{listing.type}</p>

            <ul class="keyfacts" aria-label="Key facts">
              <li><span class="kf-icon" aria-hidden="true">🛏</span><span class="kf-num">{listing.beds}</span> bedrooms</li>
              <li><span class="kf-icon" aria-hidden="true">🛁</span><span class="kf-num">{listing.baths}</span> bathroom</li>
              <li><span class="kf-icon" aria-hidden="true">🛋</span><span class="kf-num">{listing.receptions}</span> reception</li>
              <li><span class="kf-icon" aria-hidden="true">📐</span><span class="kf-num">{listing.size}</span></li>
            </ul>
          </div>

          <!-- Section tabs, like a portal property page -->
          <nav class="tabs" aria-label="Listing sections">
            <a href="#overview" class="tab is-active">Overview</a>
            <a href="#features" class="tab">Features</a>
            <a href="#map" class="tab">Map</a>
          </nav>

          <section id="overview" class="card block" aria-labelledby="desc-title">
            <h2 id="desc-title">Overview</h2>
            <p>
              A fictional, demo-only rental listing created for Premier Housing sales
              demonstrations. It shows how a portal-style property detail page can route an
              enquiry into the Premier Housing responder, dashboard classification, and the
              approved demo owner alert path.
            </p>
            <p>
              No real address, photographs, live portal listing, resident profile,
              or enquiry record is used anywhere on this page. Every image is a styled placeholder
              and every figure is invented for testing.
            </p>

            <dl class="specs">
              <div><dt>Property type</dt><dd>{listing.type}</dd></div>
              <div><dt>EPC rating</dt><dd>{listing.epc} (synthetic)</dd></div>
              <div><dt>Council tax</dt><dd>{listing.council} (synthetic)</dd></div>
              <div><dt>Size</dt><dd>{listing.size}</dd></div>
              <div><dt>Listed by</dt><dd>{listing.agent}</dd></div>
            </dl>
          </section>

          <section id="features" class="card block" aria-labelledby="features-title">
            <h2 id="features-title">Features</h2>
            <ul class="features">
              {features.map((f) => <li>{f}</li>)}
            </ul>
          </section>

          <section id="map" class="card block" aria-labelledby="map-title">
            <h2 id="map-title">Map</h2>
            <div class="map" aria-hidden="true">
              <span class="map-pin">📍</span>
              <span>Approximate area map placeholder — Bradford BD1 (synthetic)</span>
            </div>
          </section>
        </article>

        <!-- Sticky enquiry sidebar with agent panel + primary CTA -->
        <aside class="sidebar" aria-label="Enquire about this property">
          <div class="card enquire-card">
            <div class="agent-panel">
              <span class="agent-logo" aria-hidden="true">PH</span>
              <div class="agent-meta">
                <p class="agent-name">Premier Housing Lettings</p>
                <p class="agent-sub">Synthetic demo branch · Bradford</p>
              </div>
            </div>

            <p class="card-price">{listing.price}</p>
            <p class="card-note">
              Request a synthetic property evaluation. Your enquiry is sent only to the controlled
              Premier Housing demo responder.
            </p>

            <button type="button" class="btn btn-primary cta" data-open-form>Get evaluation</button>

            <div class="contact-row">
              <button type="button" class="btn btn-ghost" disabled aria-disabled="true" tabindex="-1">Call agent</button>
              <button type="button" class="btn btn-ghost" disabled aria-disabled="true" tabindex="-1">Email agent</button>
            </div>
            <p class="card-foot">Call and email are inactive in this demo. Use synthetic contact details for smoke testing.</p>
          </div>
        </aside>
      </div>
    </main>

    <footer class="portal-foot">
      <p>Synthetic portal demo, not affiliated with Zoopla.</p>
      <p>Premier Housing demo environment · Brackstone controlled testing only.</p>
    </footer>

    <!-- Enquiry modal: opens from any "Get evaluation" CTA, submits only to the endpoint -->
    <div class="modal-overlay" id="enquireModal" hidden>
      <div class="modal" role="dialog" aria-modal="true" aria-labelledby="form-title">
        <button type="button" class="modal-close" data-close-form aria-label="Close form">×</button>
        <p class="eyebrow">Controlled synthetic form</p>
        <h2 id="form-title">Get evaluation</h2>
        <p class="modal-intro">
          This form posts only to the approved Premier Housing demo endpoint. No data leaves the
          controlled demo path.
        </p>
        <form id="demo2Enquiry" novalidate>
          <input type="text" name="company" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <label>
            Name
            <input name="name" autocomplete="off" required placeholder="Demo Visitor" />
          </label>
          <label>
            Phone
            <input name="phone" autocomplete="off" required placeholder="07700 900310" />
          </label>
          <label>
            Email
            <input name="email" type="email" autocomplete="off" required placeholder="demo@example.com" />
          </label>
          <label>
            Message
            <textarea name="message" rows="4" required placeholder="I would like a synthetic evaluation / viewing for the demo apartment."></textarea>
          </label>
          <input type="hidden" name="property" value={listing.title} />
          <input type="hidden" name="listing_url" value={pageUrl} />
          <button type="submit" class="btn btn-primary cta">Submit demo enquiry</button>
          <p class="status" data-status role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>

    <style>
      :root {
        color-scheme: light;
        --ink: #1c1230;
        --muted: #6b6480;
        --line: rgba(28, 18, 48, 0.1);
        /* Zoopla-like portal palette: deep purple + magenta accent */
        --brand: #6a0f8a;
        --brand-dark: #4a0a63;
        --accent: #e6157b;
        --accent-dark: #c10f66;
        --paper: #ffffff;
        --bg: #f5f3f7;
        font-family: "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
        color: var(--ink);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
      }
      h1, h2, p, dl, dd { margin: 0; }

      .disclaimer {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        justify-content: center;
        background: #fff3cd;
        border-bottom: 1px solid #e8d595;
        padding: 8px 16px;
        font-size: 0.88rem;
        text-align: center;
      }
      .disclaimer strong { color: var(--brand-dark); }

      /* Purple portal header */
      .topbar {
        background: linear-gradient(100deg, var(--brand-dark), var(--brand) 60%, #7d18a0);
        color: #fff;
        box-shadow: 0 4px 18px rgba(74, 10, 99, 0.25);
      }
      .topbar-inner {
        width: min(1200px, calc(100% - 32px));
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 22px;
        padding: 14px 0;
        flex-wrap: wrap;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: #fff;
        font-weight: 800;
      }
      .brand-mark {
        display: grid;
        place-items: center;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: var(--accent);
        color: #fff;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
        box-shadow: 0 6px 16px rgba(230, 21, 123, 0.4);
      }
      .brand-name { font-size: 1.25rem; letter-spacing: -0.02em; }
      .topnav {
        display: flex;
        gap: 22px;
        margin-left: 8px;
        color: rgba(255, 255, 255, 0.88);
        font-weight: 600;
        font-size: 0.95rem;
      }
      .topnav span { cursor: default; }
      .topbar-actions {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 18px;
      }
      .topbar-link {
        color: rgba(255, 255, 255, 0.92);
        font-weight: 600;
        font-size: 0.95rem;
      }
      .topbar-cta { box-shadow: none; }

      /* Buttons */
      .btn {
        border: 0;
        border-radius: 999px;
        padding: 12px 22px;
        font: inherit;
        font-weight: 800;
        cursor: pointer;
        transition: background 0.15s ease, transform 0.1s ease, box-shadow 0.15s ease;
        text-align: center;
        line-height: 1.2;
      }
      .btn-primary {
        background: var(--accent);
        color: #fff;
        box-shadow: 0 12px 26px rgba(230, 21, 123, 0.28);
      }
      .btn-primary:hover, .btn-primary:focus-visible { background: var(--accent-dark); }
      .btn-primary:active { transform: translateY(1px); }
      .btn-accent { background: var(--accent); color: #fff; }
      .btn-ghost {
        background: #fff;
        color: var(--brand-dark);
        border: 1.5px solid var(--line);
        box-shadow: none;
        cursor: not-allowed;
        opacity: 0.85;
      }

      .portal {
        width: min(1200px, calc(100% - 32px));
        margin: 0 auto;
      }

      .searchbar {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: stretch;
        margin-top: 22px;
        padding: 12px;
        border-radius: 16px;
        background: var(--paper);
        border: 1px solid var(--line);
        box-shadow: 0 14px 40px rgba(74, 10, 99, 0.08);
      }
      .search-field {
        flex: 1 1 150px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 8px 14px;
        border-radius: 11px;
        background: #f6f3f8;
      }
      .search-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 800;
        color: var(--muted);
      }
      .search-value { font-weight: 800; }
      .search-go {
        display: grid;
        place-items: center;
        padding: 0 30px;
      }

      .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 18px 2px 14px;
        color: var(--muted);
        font-size: 0.86rem;
        font-weight: 600;
      }
      .breadcrumb [aria-current="page"] { color: var(--brand); font-weight: 800; }

      /* Gallery: one large left image + 2x2 smaller right tiles */
      .gallery {
        display: grid;
        grid-template-columns: minmax(0, 1.85fr) minmax(0, 1fr);
        gap: 12px;
        margin-bottom: 26px;
      }
      .shot {
        position: relative;
        display: grid;
        place-items: end start;
        border-radius: 16px;
        overflow: hidden;
        color: #fdf7fb;
        min-height: 130px;
      }
      .gallery-main { min-height: 440px; border-radius: 20px; }
      .gallery-side {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
        gap: 12px;
      }
      .shot-label {
        position: relative;
        z-index: 1;
        margin: 14px;
        padding: 5px 11px;
        border-radius: 999px;
        background: rgba(28, 18, 48, 0.5);
        font-size: 0.8rem;
        font-weight: 700;
        backdrop-filter: blur(2px);
      }
      .shot-count {
        position: absolute;
        z-index: 1;
        top: 14px;
        right: 14px;
        padding: 5px 11px;
        border-radius: 999px;
        background: rgba(28, 18, 48, 0.5);
        font-size: 0.76rem;
        font-weight: 700;
      }
      .shot-more {
        position: absolute;
        inset: 0;
        z-index: 1;
        display: grid;
        place-items: center;
        background: rgba(28, 18, 48, 0.45);
        font-weight: 800;
        font-size: 1rem;
      }
      /*
        Synthetic CSS-only placeholder "photography" — no external assets.
        Layered gradients + shapes evoke interior scenes (walls, floor, window light, furniture).
      */
      .shot-hero {
        background:
          /* window light */
          radial-gradient(120% 80% at 78% 12%, rgba(255, 240, 210, 0.55), transparent 45%),
          /* floor plane */
          linear-gradient(180deg, transparent 62%, rgba(120, 70, 40, 0.55) 62%, rgba(90, 52, 30, 0.7) 100%),
          /* sofa block */
          linear-gradient(180deg, transparent 48%, rgba(210, 180, 200, 0.4) 48%, rgba(210, 180, 200, 0.4) 62%, transparent 62%),
          /* wall */
          linear-gradient(135deg, #6a2f86, #4a0a63);
      }
      .shot-1 {
        background:
          radial-gradient(80% 60% at 30% 25%, rgba(255, 235, 200, 0.4), transparent 50%),
          linear-gradient(180deg, transparent 60%, rgba(60, 90, 110, 0.6) 60%),
          linear-gradient(135deg, #8a3aa0, #5a1d72);
      }
      .shot-2 {
        background:
          linear-gradient(180deg, transparent 55%, rgba(150, 100, 60, 0.55) 55%),
          radial-gradient(70% 70% at 70% 20%, rgba(255, 220, 235, 0.35), transparent 55%),
          linear-gradient(135deg, #b21f78, #7a1158);
      }
      .shot-3 {
        background:
          radial-gradient(90% 70% at 50% 20%, rgba(220, 245, 255, 0.4), transparent 55%),
          linear-gradient(180deg, transparent 65%, rgba(70, 110, 130, 0.5) 65%),
          linear-gradient(135deg, #5a3a98, #361f63);
      }
      .shot-4 {
        /* floor-plan style grid */
        background:
          linear-gradient(0deg, rgba(74, 10, 99, 0.9), rgba(74, 10, 99, 0.9)),
          repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.22) 0 2px, transparent 2px 24px),
          repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.22) 0 2px, transparent 2px 24px);
      }

      .layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 26px;
        align-items: start;
      }

      .card {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 10px 30px rgba(74, 10, 99, 0.06);
      }
      .listing-head { margin-bottom: 18px; }

      .badges { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
      .badge {
        padding: 6px 12px;
        border-radius: 999px;
        background: #f0eaf4;
        color: var(--brand-dark);
        font-size: 0.78rem;
        font-weight: 800;
      }
      .badge-accent { background: #fde0ee; color: var(--accent-dark); }

      .price { font-size: clamp(2rem, 4vw, 2.7rem); font-weight: 900; letter-spacing: -0.03em; color: var(--brand-dark); }
      .price-note { color: var(--muted); margin-top: 4px; font-weight: 700; }
      .listing-title { margin-top: 14px; font-size: clamp(1.4rem, 3vw, 1.9rem); letter-spacing: -0.02em; line-height: 1.15; }
      .listing-type { color: var(--muted); margin-top: 6px; font-weight: 600; }

      .keyfacts {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        list-style: none;
        padding: 18px 0 0;
        margin: 18px 0 0;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-weight: 600;
      }
      .keyfacts li {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 8px 14px;
        background: #faf8fc;
        border: 1px solid var(--line);
        border-radius: 11px;
      }
      .kf-icon { font-size: 1rem; }
      .kf-num { color: var(--ink); font-weight: 900; }

      /* Section tabs */
      .tabs {
        display: flex;
        gap: 6px;
        margin-bottom: 16px;
        border-bottom: 2px solid var(--line);
        flex-wrap: wrap;
      }
      .tab {
        padding: 11px 20px;
        text-decoration: none;
        color: var(--muted);
        font-weight: 800;
        font-size: 0.96rem;
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
        border-radius: 8px 8px 0 0;
      }
      .tab:hover { color: var(--brand); }
      .tab.is-active { color: var(--brand-dark); border-bottom-color: var(--accent); }

      .block { margin-bottom: 18px; scroll-margin-top: 18px; }
      .block h2 { font-size: 1.25rem; margin-bottom: 12px; letter-spacing: -0.01em; }
      .block p { color: var(--muted); line-height: 1.7; }
      .block p + p { margin-top: 12px; }

      .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 10px 22px;
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .features li {
        position: relative;
        padding-left: 26px;
        color: var(--ink);
        font-weight: 600;
      }
      .features li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: var(--accent);
        font-weight: 900;
      }

      .specs { display: grid; gap: 0; margin-top: 18px; }
      .specs > div {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        padding: 12px 0;
        border-bottom: 1px solid var(--line);
      }
      .specs > div:last-child { border-bottom: 0; }
      .specs dt { color: var(--muted); font-weight: 700; }
      .specs dd { font-weight: 800; text-align: right; }

      .map {
        display: grid;
        place-items: center;
        gap: 8px;
        min-height: 220px;
        border-radius: 14px;
        text-align: center;
        color: #f6ecf6;
        font-weight: 700;
        padding: 18px;
        background:
          linear-gradient(160deg, rgba(106, 15, 138, 0.92), rgba(74, 10, 99, 0.92)),
          repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.1) 0 1px, transparent 1px 32px),
          repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.1) 0 1px, transparent 1px 32px);
      }
      .map-pin { font-size: 2rem; }

      /* Sticky lead card */
      .sidebar { position: sticky; top: 18px; }
      .enquire-card { padding: 22px; }
      .agent-panel {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-bottom: 16px;
        margin-bottom: 16px;
        border-bottom: 1px solid var(--line);
      }
      .agent-logo {
        display: grid;
        place-items: center;
        width: 52px;
        height: 52px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--brand), var(--brand-dark));
        color: #fff;
        font-weight: 900;
        letter-spacing: 0.04em;
        flex-shrink: 0;
      }
      .agent-name { font-weight: 900; color: var(--brand-dark); }
      .agent-sub { color: var(--muted); font-size: 0.85rem; margin-top: 2px; }
      .card-price { font-size: 1.7rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -0.02em; }
      .card-note { color: var(--muted); line-height: 1.6; margin-top: 10px; font-size: 0.92rem; }
      .cta { width: 100%; margin-top: 16px; padding: 15px 22px; font-size: 1.02rem; }
      .contact-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px; }
      .contact-row .btn { padding: 12px 10px; font-size: 0.92rem; }
      .card-foot { color: var(--muted); font-size: 0.8rem; margin-top: 12px; text-align: center; line-height: 1.5; }

      .eyebrow {
        color: var(--accent-dark);
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .portal-foot {
        width: min(1200px, calc(100% - 32px));
        margin: 40px auto 0;
        padding: 22px 0 48px;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.86rem;
        text-align: center;
        display: grid;
        gap: 4px;
      }

      /* Modal */
      .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        display: grid;
        place-items: center;
        padding: 18px;
        background: rgba(28, 18, 48, 0.55);
        backdrop-filter: blur(3px);
      }
      .modal-overlay[hidden] { display: none; }
      .modal {
        position: relative;
        width: min(480px, 100%);
        max-height: 92vh;
        overflow-y: auto;
        background: var(--paper);
        border-radius: 22px;
        padding: 30px;
        box-shadow: 0 40px 100px rgba(28, 18, 48, 0.35);
      }
      .modal h2 { margin: 8px 0 10px; font-size: 1.7rem; letter-spacing: -0.02em; }
      .modal-intro { color: var(--muted); line-height: 1.6; margin-bottom: 18px; }
      .modal-close {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 38px;
        height: 38px;
        padding: 0;
        border: 0;
        border-radius: 50%;
        background: #f0eaf4;
        color: var(--ink);
        font-size: 1.4rem;
        line-height: 1;
        cursor: pointer;
      }
      .modal-close:hover { background: #e4dbec; }

      form { display: grid; gap: 14px; }
      label { display: grid; gap: 7px; color: #2c2240; font-weight: 800; font-size: 0.92rem; }
      input, textarea {
        width: 100%;
        border: 1px solid rgba(28, 18, 48, 0.2);
        border-radius: 12px;
        padding: 13px 14px;
        background: #fffdff;
        color: var(--ink);
        font: inherit;
      }
      input:focus, textarea:focus { outline: 2px solid var(--accent); outline-offset: 1px; border-color: transparent; }
      .honeypot { position: absolute; left: -9999px; width: 1px; height: 1px; }
      .status { min-height: 1.4em; color: var(--accent-dark); font-weight: 800; }

      @media (max-width: 980px) {
        .layout { grid-template-columns: 1fr; }
        .sidebar { position: static; }
      }
      @media (max-width: 760px) {
        .gallery { grid-template-columns: 1fr; }
        .gallery-main { min-height: 280px; }
        .gallery-side { grid-template-rows: 1fr; }
        .topnav { display: none; }
      }
      @media (max-width: 560px) {
        .topbar-link { display: none; }
      }
    </style>

    <script define:vars={{ endpoint }}>
      const overlay = document.getElementById('enquireModal');
      const form = document.getElementById('demo2Enquiry');
      const status = document.querySelector('[data-status]');
      let lastFocused = null;

      const openForm = () => {
        if (!overlay) return;
        lastFocused = document.activeElement;
        overlay.hidden = false;
        document.body.style.overflow = 'hidden';
        overlay.querySelector('input[name="name"]')?.focus();
      };
      const closeForm = () => {
        if (!overlay) return;
        overlay.hidden = true;
        document.body.style.overflow = '';
        if (lastFocused instanceof HTMLElement) lastFocused.focus();
      };

      document.querySelectorAll('[data-open-form]').forEach((el) =>
        el.addEventListener('click', openForm)
      );
      document.querySelectorAll('[data-close-form]').forEach((el) =>
        el.addEventListener('click', closeForm)
      );
      overlay?.addEventListener('click', (event) => {
        if (event.target === overlay) closeForm();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && overlay && !overlay.hidden) closeForm();
      });

      // Tabs: smooth-scroll to section and mark the active tab.
      const tabs = Array.from(document.querySelectorAll('.tab'));
      tabs.forEach((tab) =>
        tab.addEventListener('click', () => {
          tabs.forEach((t) => t.classList.remove('is-active'));
          tab.classList.add('is-active');
        })
      );

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!status) return;
        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());
        status.textContent = 'Sending demo enquiry...';
        try {
          const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          status.textContent = 'Demo enquiry sent. Check the Premier Housing responder evidence.';
          form.reset();
        } catch (error) {
          status.textContent = 'Demo enquiry did not send. Please use the controlled smoke route.';
          console.error('Premier Housing demo2 enquiry failed', error);
        }
      });
    </script>
  </body>
</html>
