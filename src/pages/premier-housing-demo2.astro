---
const endpoint = 'https://premier-housing-demo.pages.dev/api/enquire';
const pageUrl = 'https://brackstonedigital.co.uk/premier-housing-demo2/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Premier Housing Synthetic Portal Demo</title>
    <meta
      name="description"
      content="Synthetic Premier Housing portal-style enquiry demo page for controlled Brackstone testing only."
    />
    <link rel="canonical" href={pageUrl} />
  </head>
  <body>
    <main class="portal-demo" data-enquire-endpoint={endpoint}>
      <section class="notice" aria-label="Demo notice">
        <strong>Demo-only page.</strong>
        <span>Synthetic portal demo, not affiliated with Zoopla.</span>
      </section>

      <header class="hero">
        <p class="eyebrow">Synthetic property portal preview</p>
        <h1>Premier Housing enquiry flow demo</h1>
        <p class="hero-copy">
          This single synthetic property shows how a portal-style enquiry can flow into the Premier Housing responder, dashboard classification, and approved demo owner alert path.
        </p>
      </header>

      <section class="listing-card" aria-labelledby="listing-title">
        <div class="visual" aria-hidden="true">
          <div class="window-grid">
            <span></span><span></span><span></span><span></span>
          </div>
          <p>Demo property image placeholder</p>
        </div>

        <article class="listing-copy">
          <p class="badge">Synthetic listing</p>
          <h2 id="listing-title">2 bedroom demo apartment, Premier House, Bradford</h2>
          <p class="price">£725 pcm</p>
          <ul class="facts" aria-label="Property facts">
            <li>2 bedrooms</li>
            <li>1 bathroom</li>
            <li>Managed viewing request</li>
          </ul>
          <p>
            A fictional, demo-only rental listing created for Premier Housing sales demonstrations. No real address, photos, portal listing, resident, or enquiry data is used on this page.
          </p>
          <button type="button" class="open-form" data-open-form>Enquire Now</button>
        </article>
      </section>

      <section class="form-panel" id="enquire" aria-labelledby="form-title">
        <div>
          <p class="eyebrow">Controlled synthetic form</p>
          <h2 id="form-title">Send a demo enquiry</h2>
          <p>
            The form posts only to the approved Premier Housing demo endpoint. Use synthetic contact details for smoke testing.
          </p>
        </div>
        <form id="demo2Enquiry" novalidate>
          <input type="text" name="company" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <label>
            Name
            <input name="name" autocomplete="off" required placeholder="Demo Visitor" />
          </label>
          <label>
            Phone
            <input name="phone" autocomplete="off" required placeholder="07700 900310" />
          </label>
          <label>
            Email
            <input name="email" type="email" autocomplete="off" required placeholder="demo@example.com" />
          </label>
          <label>
            Message
            <textarea name="message" rows="4" required placeholder="I would like to arrange a synthetic viewing for the demo apartment."></textarea>
          </label>
          <input type="hidden" name="property" value="2 bedroom demo apartment, Premier House, Bradford" />
          <input type="hidden" name="listing_url" value={pageUrl} />
          <button type="submit">Submit demo enquiry</button>
          <p class="status" data-status role="status" aria-live="polite"></p>
        </form>
      </section>
    </main>

    <style>
      :root {
        color-scheme: light;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f3efe6;
        color: #17231f;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(37, 99, 75, 0.16), transparent 34rem),
          linear-gradient(180deg, #fffaf0 0%, #f0eadf 100%);
      }
      .portal-demo {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0 64px;
      }
      .notice {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        border: 1px solid #d7c391;
        background: #fff7d9;
        border-radius: 999px;
        padding: 12px 18px;
        font-size: 0.95rem;
      }
      .hero {
        padding: clamp(48px, 8vw, 88px) 0 36px;
      }
      .eyebrow,
      .badge {
        margin: 0 0 10px;
        color: #2d6b55;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }
      h1,
      h2,
      p {
        margin: 0;
      }
      h1 {
        max-width: 760px;
        font-size: clamp(2.8rem, 8vw, 6.8rem);
        line-height: 0.9;
        letter-spacing: -0.08em;
      }
      .hero-copy {
        max-width: 680px;
        margin-top: 24px;
        color: #5c6258;
        font-size: clamp(1.05rem, 2vw, 1.35rem);
        line-height: 1.65;
      }
      .listing-card,
      .form-panel {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
        gap: clamp(22px, 4vw, 48px);
        align-items: stretch;
        border: 1px solid rgba(23, 35, 31, 0.12);
        border-radius: 34px;
        background: rgba(255, 255, 255, 0.78);
        box-shadow: 0 24px 80px rgba(50, 39, 20, 0.12);
        padding: clamp(20px, 4vw, 34px);
      }
      .visual {
        min-height: 360px;
        display: grid;
        place-items: center;
        border-radius: 26px;
        background:
          linear-gradient(135deg, rgba(34, 97, 73, 0.18), rgba(176, 141, 87, 0.22)),
          repeating-linear-gradient(45deg, rgba(255,255,255,0.38) 0 12px, transparent 12px 24px);
        color: #244636;
        text-align: center;
        font-weight: 800;
      }
      .window-grid {
        display: grid;
        grid-template-columns: repeat(2, 74px);
        gap: 10px;
        margin-bottom: 18px;
      }
      .window-grid span {
        display: block;
        height: 74px;
        border-radius: 16px;
        background: rgba(255,255,255,0.78);
        border: 1px solid rgba(36,70,54,0.18);
      }
      .listing-copy {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .listing-copy h2,
      .form-panel h2 {
        font-size: clamp(2rem, 4vw, 3.6rem);
        line-height: 0.98;
        letter-spacing: -0.05em;
      }
      .price {
        margin-top: 18px;
        font-size: 1.7rem;
        color: #265f49;
        font-weight: 900;
      }
      .facts {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 0;
        margin: 22px 0;
        list-style: none;
      }
      .facts li {
        border-radius: 999px;
        background: #edf5ef;
        color: #244636;
        padding: 9px 13px;
        font-size: 0.95rem;
        font-weight: 700;
      }
      .listing-copy p:not(.badge):not(.price),
      .form-panel p:not(.eyebrow):not(.status) {
        color: #5c6258;
        line-height: 1.7;
      }
      button {
        border: 0;
        border-radius: 999px;
        background: #1f5a45;
        color: #fff;
        padding: 14px 22px;
        margin-top: 26px;
        font: inherit;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 14px 32px rgba(31, 90, 69, 0.2);
      }
      button:hover,
      button:focus-visible {
        background: #163f31;
      }
      .form-panel {
        margin-top: 28px;
      }
      form {
        display: grid;
        gap: 14px;
      }
      label {
        display: grid;
        gap: 7px;
        color: #28352f;
        font-weight: 800;
      }
      input,
      textarea {
        width: 100%;
        box-sizing: border-box;
        border: 1px solid rgba(23, 35, 31, 0.2);
        border-radius: 16px;
        padding: 13px 14px;
        background: #fffdf8;
        color: #17231f;
        font: inherit;
      }
      .honeypot {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
      }
      .status {
        min-height: 1.5em;
        color: #1f5a45;
        font-weight: 800;
      }
      @media (max-width: 780px) {
        .listing-card,
        .form-panel {
          grid-template-columns: 1fr;
        }
        .visual {
          min-height: 260px;
        }
      }
    </style>

    <script define:vars={{ endpoint }}>
      const form = document.getElementById('demo2Enquiry');
      const status = document.querySelector('[data-status]');
      const opener = document.querySelector('[data-open-form]');
      opener?.addEventListener('click', () => {
        document.getElementById('enquire')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!status) return;
        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());
        status.textContent = 'Sending demo enquiry...';
        try {
          const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          status.textContent = 'Demo enquiry sent. Check the Premier Housing responder evidence.';
          form.reset();
        } catch (error) {
          status.textContent = 'Demo enquiry did not send. Please use the controlled smoke route.';
          console.error('Premier Housing demo2 enquiry failed', error);
        }
      });
    </script>
  </body>
</html>
