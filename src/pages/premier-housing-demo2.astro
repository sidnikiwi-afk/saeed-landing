---
const endpoint = 'https://premier-housing-demo.pages.dev/api/enquire';
const pageUrl = 'https://brackstonedigital.co.uk/premier-housing-demo2/';

// Exactly one synthetic listing. No real address, photos, portal data, or people.
const listing = {
  title: '2 bedroom apartment, Premier House, Bradford BD1',
  price: '£725 pcm',
  priceNote: '£167 pw · Tenancy available now',
  type: 'Apartment · Leasehold',
  beds: 2,
  baths: 1,
  receptions: 1,
  size: '742 sq ft',
  epc: 'C',
  council: 'Band A',
  added: 'Listed 3 days ago',
  agent: 'Premier Housing Lettings (synthetic demo branch)',
};

const galleryShots = [
  'Reception room',
  'Kitchen',
  'Main bedroom',
  'Bathroom',
  'Floor plan',
];

const features = [
  'Two double bedrooms',
  'Open-plan living / kitchen',
  'Allocated parking space',
  'Double glazing throughout',
  'Gas central heating',
  'Within walking distance of the city centre',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Premier Housing Synthetic Portal Demo</title>
    <meta
      name="description"
      content="Synthetic Premier Housing portal-style enquiry demo page for controlled Brackstone testing only."
    />
    <link rel="canonical" href={pageUrl} />
  </head>
  <body>
    <main class="portal" data-enquire-endpoint={endpoint}>
      <!-- Persistent demo disclaimer (exact wording must be preserved) -->
      <div class="disclaimer" role="note">
        <strong>Demo-only page.</strong>
        <span>Synthetic portal demo, not affiliated with Zoopla.</span>
      </div>

      <!-- Portal-style top bar -->
      <header class="topbar">
        <a class="brand" href="#" aria-label="Premier Housing demo home">
          <span class="brand-mark" aria-hidden="true">PH</span>
          <span class="brand-name">Premier Housing</span>
        </a>
        <nav class="topnav" aria-label="Demo navigation">
          <span>Rent</span>
          <span>Buy</span>
          <span>Sold prices</span>
          <span>Find agents</span>
        </nav>
        <button type="button" class="topbar-cta" data-open-form>Get evaluation</button>
      </header>

      <!-- Synthetic search bar mockup (non-functional, illustrative only) -->
      <section class="searchbar" aria-label="Synthetic search (demo only)">
        <div class="search-field">
          <span class="search-label">Location</span>
          <span class="search-value">Bradford, BD1</span>
        </div>
        <div class="search-field">
          <span class="search-label">Type</span>
          <span class="search-value">Homes to rent</span>
        </div>
        <div class="search-field">
          <span class="search-label">Beds</span>
          <span class="search-value">2+</span>
        </div>
        <span class="search-go" aria-hidden="true">Search</span>
      </section>

      <nav class="breadcrumb" aria-label="Breadcrumb">
        <span>Rent</span>
        <span aria-hidden="true">›</span>
        <span>Bradford</span>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Premier House (demo)</span>
      </nav>

      <!-- CSS-only synthetic gallery. No external images. -->
      <section class="gallery" aria-label="Synthetic property gallery (placeholder images)">
        <figure class="gallery-main shot shot-room" aria-hidden="true">
          <span class="shot-label">Reception room</span>
          <span class="shot-count">1 / {galleryShots.length} · synthetic placeholders</span>
        </figure>
        <div class="gallery-thumbs" aria-hidden="true">
          {galleryShots.map((label, i) => (
            <figure class={`shot thumb shot-${i}`}>
              <span class="shot-label">{label}</span>
            </figure>
          ))}
        </div>
      </section>

      <div class="layout">
        <article class="detail">
          <div class="badges">
            <span class="badge badge-accent">Synthetic listing</span>
            <span class="badge">{listing.added}</span>
          </div>

          <p class="price">{listing.price}</p>
          <p class="price-note">{listing.priceNote}</p>
          <h1 class="listing-title">{listing.title}</h1>
          <p class="listing-type">{listing.type}</p>

          <ul class="keyfacts" aria-label="Key facts">
            <li><span class="kf-num">{listing.beds}</span> bedrooms</li>
            <li><span class="kf-num">{listing.baths}</span> bathroom</li>
            <li><span class="kf-num">{listing.receptions}</span> reception</li>
            <li><span class="kf-num">{listing.size}</span></li>
          </ul>

          <section class="block" aria-labelledby="features-title">
            <h2 id="features-title">Property features</h2>
            <ul class="features">
              {features.map((f) => <li>{f}</li>)}
            </ul>
          </section>

          <section class="block" aria-labelledby="desc-title">
            <h2 id="desc-title">Description</h2>
            <p>
              A fictional, demo-only rental listing created for Premier Housing sales
              demonstrations. It shows how a portal-style property detail page can route an
              enquiry into the Premier Housing responder, dashboard classification, and the
              approved demo owner alert path.
            </p>
            <p>
              No real address, photographs, live portal listing, resident profile,
              or enquiry record is used anywhere on this page. Every image is a styled placeholder
              and every figure is invented for testing.
            </p>
          </section>

          <section class="block specs" aria-labelledby="specs-title">
            <h2 id="specs-title">At a glance</h2>
            <dl>
              <div><dt>Property type</dt><dd>{listing.type}</dd></div>
              <div><dt>EPC rating</dt><dd>{listing.epc} (synthetic)</dd></div>
              <div><dt>Council tax</dt><dd>{listing.council} (synthetic)</dd></div>
              <div><dt>Size</dt><dd>{listing.size}</dd></div>
              <div><dt>Listed by</dt><dd>{listing.agent}</dd></div>
            </dl>
          </section>

          <section class="block" aria-labelledby="map-title">
            <h2 id="map-title">Location</h2>
            <div class="map" aria-hidden="true">
              <span class="map-pin">📍</span>
              <span>Approximate area map placeholder — Bradford BD1 (synthetic)</span>
            </div>
          </section>
        </article>

        <!-- Sticky enquiry sidebar with the primary CTA -->
        <aside class="sidebar" aria-label="Enquire about this property">
          <div class="enquire-card">
            <p class="card-eyebrow">Interested in this demo home?</p>
            <p class="card-price">{listing.price}</p>
            <p class="card-note">
              Request a synthetic property evaluation. Your enquiry is sent only to the controlled
              Premier Housing demo responder.
            </p>
            <button type="button" class="cta" data-open-form>Get evaluation</button>
            <p class="card-foot">Use synthetic contact details for smoke testing.</p>
          </div>
        </aside>
      </div>

      <footer class="portal-foot">
        <p>Synthetic portal demo, not affiliated with Zoopla.</p>
        <p>Premier Housing demo environment · Brackstone controlled testing only.</p>
      </footer>
    </main>

    <!-- Enquiry modal: opens from any "Get evaluation" CTA, submits only to the endpoint -->
    <div class="modal-overlay" id="enquireModal" hidden>
      <div class="modal" role="dialog" aria-modal="true" aria-labelledby="form-title">
        <button type="button" class="modal-close" data-close-form aria-label="Close form">×</button>
        <p class="eyebrow">Controlled synthetic form</p>
        <h2 id="form-title">Get evaluation</h2>
        <p class="modal-intro">
          This form posts only to the approved Premier Housing demo endpoint. No data leaves the
          controlled demo path.
        </p>
        <form id="demo2Enquiry" novalidate>
          <input type="text" name="company" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <label>
            Name
            <input name="name" autocomplete="off" required placeholder="Demo Visitor" />
          </label>
          <label>
            Phone
            <input name="phone" autocomplete="off" required placeholder="07700 900310" />
          </label>
          <label>
            Email
            <input name="email" type="email" autocomplete="off" required placeholder="demo@example.com" />
          </label>
          <label>
            Message
            <textarea name="message" rows="4" required placeholder="I would like a synthetic evaluation / viewing for the demo apartment."></textarea>
          </label>
          <input type="hidden" name="property" value={listing.title} />
          <input type="hidden" name="listing_url" value={pageUrl} />
          <button type="submit" class="cta">Submit demo enquiry</button>
          <p class="status" data-status role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>

    <style>
      :root {
        color-scheme: light;
        --ink: #11221c;
        --muted: #5c6a63;
        --line: rgba(17, 34, 28, 0.12);
        --brand: #1f5a45;
        --brand-dark: #143c2e;
        --accent: #b8862f;
        --paper: #ffffff;
        --bg: #f4f1ea;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--ink);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at 12% -10%, rgba(31, 90, 69, 0.1), transparent 32rem),
          var(--bg);
      }
      h1, h2, p, dl, dd { margin: 0; }
      .portal {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
        padding-bottom: 56px;
      }

      .disclaimer {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        justify-content: center;
        background: #fff4d6;
        border: 1px solid #e3cd8e;
        border-radius: 0 0 14px 14px;
        padding: 9px 16px;
        font-size: 0.9rem;
        text-align: center;
      }
      .disclaimer strong { color: var(--brand-dark); }

      .topbar {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 18px 4px;
        border-bottom: 1px solid var(--line);
        flex-wrap: wrap;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--ink);
        font-weight: 900;
      }
      .brand-mark {
        display: grid;
        place-items: center;
        width: 38px;
        height: 38px;
        border-radius: 11px;
        background: var(--brand);
        color: #fff;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
      }
      .brand-name { font-size: 1.2rem; letter-spacing: -0.02em; }
      .topnav {
        display: flex;
        gap: 20px;
        margin-left: 12px;
        color: var(--muted);
        font-weight: 700;
        font-size: 0.95rem;
      }
      .topbar-cta { margin-left: auto; }

      .searchbar {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: stretch;
        margin-top: 22px;
        padding: 12px;
        border-radius: 18px;
        background: var(--paper);
        border: 1px solid var(--line);
        box-shadow: 0 16px 44px rgba(40, 33, 16, 0.08);
      }
      .search-field {
        flex: 1 1 150px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 8px 14px;
        border-radius: 12px;
        background: #f6f4ee;
      }
      .search-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 800;
        color: var(--muted);
      }
      .search-value { font-weight: 800; }
      .search-go {
        display: grid;
        place-items: center;
        padding: 0 26px;
        border-radius: 12px;
        background: var(--brand);
        color: #fff;
        font-weight: 900;
      }

      .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 20px 2px 14px;
        color: var(--muted);
        font-size: 0.88rem;
        font-weight: 700;
      }
      .breadcrumb [aria-current="page"] { color: var(--ink); }

      .gallery {
        display: grid;
        grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
        gap: 12px;
        margin-bottom: 26px;
      }
      .shot {
        position: relative;
        display: grid;
        place-items: end start;
        border-radius: 20px;
        overflow: hidden;
        color: #f4fbf7;
        min-height: 120px;
      }
      .gallery-main { min-height: 420px; border-radius: 24px; }
      .gallery-thumbs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      .shot-label {
        position: relative;
        z-index: 1;
        margin: 14px;
        padding: 5px 11px;
        border-radius: 999px;
        background: rgba(11, 34, 28, 0.55);
        font-size: 0.82rem;
        font-weight: 800;
        backdrop-filter: blur(2px);
      }
      .shot-count {
        position: absolute;
        z-index: 1;
        top: 14px;
        right: 14px;
        padding: 5px 11px;
        border-radius: 999px;
        background: rgba(11, 34, 28, 0.55);
        font-size: 0.78rem;
        font-weight: 700;
      }
      /* Synthetic CSS-only placeholder "photography" — no external assets */
      .shot-room, .gallery-main {
        background:
          linear-gradient(115deg, rgba(31,90,69,0.92), rgba(20,60,46,0.92)),
          repeating-linear-gradient(45deg, rgba(255,255,255,0.07) 0 16px, transparent 16px 32px);
      }
      .shot-0 { background: linear-gradient(135deg, #2c6c54, #1c4a39); }
      .shot-1 { background: linear-gradient(135deg, #3a7a60, #245443); }
      .shot-2 { background: linear-gradient(135deg, #b8862f, #8c651f); }
      .shot-3 { background: linear-gradient(135deg, #4a6b60, #2e463f); }
      .shot-4 {
        background:
          linear-gradient(0deg, rgba(20,60,46,0.85), rgba(20,60,46,0.85)),
          repeating-linear-gradient(0deg, rgba(255,255,255,0.18) 0 2px, transparent 2px 22px),
          repeating-linear-gradient(90deg, rgba(255,255,255,0.18) 0 2px, transparent 2px 22px);
      }

      .layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 28px;
        align-items: start;
      }

      .badges { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
      .badge {
        padding: 6px 12px;
        border-radius: 999px;
        background: #edf3ef;
        color: var(--brand-dark);
        font-size: 0.8rem;
        font-weight: 800;
      }
      .badge-accent { background: #fbeccd; color: #7c5410; }

      .price { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 900; letter-spacing: -0.03em; color: var(--brand-dark); }
      .price-note { color: var(--muted); margin-top: 4px; font-weight: 700; }
      .listing-title { margin-top: 16px; font-size: clamp(1.4rem, 3vw, 2rem); letter-spacing: -0.02em; line-height: 1.15; }
      .listing-type { color: var(--muted); margin-top: 6px; font-weight: 700; }

      .keyfacts {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        list-style: none;
        padding: 18px 0;
        margin: 18px 0 4px;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        color: var(--muted);
        font-weight: 700;
      }
      .keyfacts li {
        display: flex;
        align-items: baseline;
        gap: 6px;
        padding: 8px 14px;
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 12px;
      }
      .kf-num { color: var(--ink); font-weight: 900; }

      .block { margin-top: 30px; }
      .block h2 { font-size: 1.25rem; margin-bottom: 12px; letter-spacing: -0.01em; }
      .block p { color: var(--muted); line-height: 1.7; }
      .block p + p { margin-top: 12px; }

      .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 10px 22px;
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .features li {
        position: relative;
        padding-left: 26px;
        color: var(--ink);
        font-weight: 600;
      }
      .features li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: var(--brand);
        font-weight: 900;
      }

      .specs dl { display: grid; gap: 0; }
      .specs dl > div {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        padding: 12px 0;
        border-bottom: 1px solid var(--line);
      }
      .specs dt { color: var(--muted); font-weight: 700; }
      .specs dd { font-weight: 800; text-align: right; }

      .map {
        display: grid;
        place-items: center;
        gap: 8px;
        min-height: 200px;
        border-radius: 18px;
        text-align: center;
        color: #eaf4ef;
        font-weight: 700;
        padding: 18px;
        background:
          linear-gradient(160deg, rgba(31,90,69,0.9), rgba(20,60,46,0.9)),
          repeating-linear-gradient(0deg, rgba(255,255,255,0.08) 0 1px, transparent 1px 30px),
          repeating-linear-gradient(90deg, rgba(255,255,255,0.08) 0 1px, transparent 1px 30px);
      }
      .map-pin { font-size: 2rem; }

      .sidebar { position: sticky; top: 18px; }
      .enquire-card {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 22px;
        padding: 24px;
        box-shadow: 0 24px 70px rgba(40, 33, 16, 0.12);
      }
      .card-eyebrow { font-weight: 800; color: var(--brand-dark); }
      .card-price { font-size: 1.7rem; font-weight: 900; color: var(--brand-dark); margin-top: 6px; letter-spacing: -0.02em; }
      .card-note { color: var(--muted); line-height: 1.6; margin-top: 12px; font-size: 0.95rem; }
      .card-foot { color: var(--muted); font-size: 0.82rem; margin-top: 12px; text-align: center; }

      .eyebrow {
        color: var(--brand);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      button {
        border: 0;
        border-radius: 999px;
        background: var(--brand);
        color: #fff;
        padding: 13px 22px;
        font: inherit;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 14px 30px rgba(31, 90, 69, 0.22);
        transition: background 0.15s ease, transform 0.1s ease;
      }
      button:hover, button:focus-visible { background: var(--brand-dark); }
      button:active { transform: translateY(1px); }
      .cta { width: 100%; margin-top: 16px; padding: 15px 22px; font-size: 1.02rem; }
      .topbar-cta { padding: 11px 20px; box-shadow: none; }

      .portal-foot {
        margin-top: 48px;
        padding-top: 22px;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.88rem;
        text-align: center;
        display: grid;
        gap: 4px;
      }

      /* Modal */
      .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        display: grid;
        place-items: center;
        padding: 18px;
        background: rgba(11, 22, 18, 0.55);
        backdrop-filter: blur(3px);
      }
      .modal-overlay[hidden] { display: none; }
      .modal {
        position: relative;
        width: min(480px, 100%);
        max-height: 92vh;
        overflow-y: auto;
        background: var(--paper);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.3);
      }
      .modal h2 { margin: 8px 0 10px; font-size: 1.7rem; letter-spacing: -0.02em; }
      .modal-intro { color: var(--muted); line-height: 1.6; margin-bottom: 18px; }
      .modal-close {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 38px;
        height: 38px;
        padding: 0;
        border-radius: 50%;
        background: #eef2ef;
        color: var(--ink);
        font-size: 1.4rem;
        line-height: 1;
        box-shadow: none;
      }
      .modal-close:hover { background: #e0e6e1; }

      form { display: grid; gap: 14px; }
      label { display: grid; gap: 7px; color: #28352f; font-weight: 800; font-size: 0.92rem; }
      input, textarea {
        width: 100%;
        border: 1px solid rgba(17, 34, 28, 0.2);
        border-radius: 14px;
        padding: 13px 14px;
        background: #fffdf9;
        color: var(--ink);
        font: inherit;
      }
      input:focus, textarea:focus { outline: 2px solid var(--brand); outline-offset: 1px; border-color: transparent; }
      .honeypot { position: absolute; left: -9999px; width: 1px; height: 1px; }
      .status { min-height: 1.4em; color: var(--brand); font-weight: 800; }

      @media (max-width: 900px) {
        .layout { grid-template-columns: 1fr; }
        .sidebar { position: static; }
        .gallery { grid-template-columns: 1fr; }
        .gallery-main { min-height: 280px; }
      }
      @media (max-width: 560px) {
        .topnav { display: none; }
        .topbar-cta { margin-left: auto; }
      }
    </style>

    <script define:vars={{ endpoint }}>
      const overlay = document.getElementById('enquireModal');
      const form = document.getElementById('demo2Enquiry');
      const status = document.querySelector('[data-status]');
      let lastFocused = null;

      const openForm = () => {
        if (!overlay) return;
        lastFocused = document.activeElement;
        overlay.hidden = false;
        document.body.style.overflow = 'hidden';
        overlay.querySelector('input[name="name"]')?.focus();
      };
      const closeForm = () => {
        if (!overlay) return;
        overlay.hidden = true;
        document.body.style.overflow = '';
        if (lastFocused instanceof HTMLElement) lastFocused.focus();
      };

      document.querySelectorAll('[data-open-form]').forEach((el) =>
        el.addEventListener('click', openForm)
      );
      document.querySelectorAll('[data-close-form]').forEach((el) =>
        el.addEventListener('click', closeForm)
      );
      overlay?.addEventListener('click', (event) => {
        if (event.target === overlay) closeForm();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && overlay && !overlay.hidden) closeForm();
      });

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!status) return;
        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());
        status.textContent = 'Sending demo enquiry...';
        try {
          const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          status.textContent = 'Demo enquiry sent. Check the Premier Housing responder evidence.';
          form.reset();
        } catch (error) {
          status.textContent = 'Demo enquiry did not send. Please use the controlled smoke route.';
          console.error('Premier Housing demo2 enquiry failed', error);
        }
      });
    </script>
  </body>
</html>
